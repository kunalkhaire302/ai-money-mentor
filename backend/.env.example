# AI Money Mentor — Environment Configuration
# DO NOT commit the real .env file to Git!

# Authentication
JWT_SECRET_KEY=your_super_secret_hmac_jwt_key_here

# LLM Providers (LangGraph / Empathic Voice Routing)
LLM_API_KEY=sk-your-llm-api-key

# WhatsApp / Twilio Integration
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
WHATSAPP_TOKEN=your_whatsapp_token_here

# Account Aggregator / Webhooks
WEBHOOK_SECRET=your_secure_webhook_secret_here

# Machine Learning (Kaggle Dataset Access)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# Optional: CORS Overrides for Production
ALLOWED_ORIGINS=http://localhost:3000,https://ai-money-mentor-n5kt.onrender.com
